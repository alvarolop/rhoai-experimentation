FROM registry.access.redhat.com/ubi9/python-312

LABEL maintainer="Alvaro Lopez Medina"
LABEL description="Pre-built image for RHOAI Kubeflow Pipeline components in disconnected environments"
LABEL io.openshift.tags="rhoai,kubeflow,pipelines,python,ml,data-science"
LABEL io.k8s.description="Unified component image for Red Hat OpenShift AI Pipelines with pre-installed ML libraries, avoiding pip install at runtime"
LABEL io.openshift.expose-services=""
LABEL version="1.0"

USER 0

# Install Python packages for Kubeflow pipeline components
# All packages pre-installed to support disconnected/air-gapped environments
# Versions aligned with component requirements and RHOAI 3.3.x compatibility

# Core ML and data science stack
RUN pip install --no-cache-dir \
    # ML training and inference
    scikit-learn==1.5.2 \
    pandas==2.2.2 \
    numpy==1.26.4 \
    # ONNX model conversion and export
    skl2onnx==1.17.0 \
    onnx==1.16.0 \
    # Cloud storage client (S3/MinIO)
    boto3==1.37.0 \
    # Kubernetes API client
    kubernetes==31.0.0 \
    # HTTP client for REST APIs
    requests==2.32.3

# Set working directory
WORKDIR /workspace

# Set permissions for OpenShift arbitrary user IDs (required for random UIDs)
RUN chown -R 1001:0 /workspace && \
    chmod -R g=u /workspace

# Switch to non-root user
USER 1001

CMD ["/bin/bash"]
