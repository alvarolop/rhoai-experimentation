<mxfile host="app.diagrams.net">
  <diagram id="pipeline-arch" name="Pipeline Architecture">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Row 1: Developer & Git (External) -->
        <mxCell id="2" value="Developer" style="shape=umlActor;verticalLabelPosition=bottom;labelBackgroundColor=#ffffff;verticalAlign=top;html=1;fontSize=12;" vertex="1" parent="1">
          <mxCell id="3" value="Git&#xa;Repository" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#4472c4;strokeWidth=2;fontSize=12;dashed=1;dashPattern=8 8;" vertex="1" parent="1">
            <mxGeometry x="100" y="100" width="120" height="60" as="geometry"/>
          </mxCell>

          <mxGeometry x="35" y="100" width="30" height="60" as="geometry"/>
        </mxCell>

        <!--Row 2: Internal System - Horizontal Flow -->

        <!-- Main container -->
        <mxCell id="4" value="OpenShift AI Pipeline System" style="rounded=1;whiteSpace=wrap;html=1;strokeColor=#ee0000;strokeWidth=3;fillColor=#fff5f5;fontStyle=1;fontSize=14;align=left;verticalAlign=top;spacingTop=5;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="200" width="1020" height="250" as="geometry"/>
        </mxCell>

        <!-- Step 1: EventListener -->
        <mxCell id="5" value="1. EventListener&#xa;&amp; Triggers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f9ff;strokeColor=#4472c4;strokeWidth=2;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="110" y="250" width="130" height="70" as="geometry"/>
        </mxCell>

        <!-- Step 2: Quality Gates -->
        <mxCell id="6" value="2. Quality Gates&#xa;(Lint, Test, Scan)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#70ad47;strokeWidth=2;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="270" y="250" width="130" height="70" as="geometry"/>
        </mxCell>

        <!-- Step 3: Execute Pipeline -->
        <mxCell id="7" value="3. Execute&#xa;DS Pipeline" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3cd;strokeColor=#ffa500;strokeWidth=3;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="250" width="130" height="70" as="geometry"/>
        </mxCell>

        <!-- Step 4: ML Components (Sequential) -->
        <mxCell id="8" value="4. ML Workflow&#xa;Validate→Data→Train&#xa;→Register→Export" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5ff;strokeColor=#7f7fff;strokeWidth=2;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="590" y="250" width="140" height="70" as="geometry"/>
        </mxCell>

        <!-- Step 5: Deploy -->
        <mxCell id="9" value="5. Deploy&#xa;Model" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#70ad47;strokeWidth=2;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="760" y="250" width="120" height="70" as="geometry"/>
        </mxCell>

        <!-- Horizontal Flow Arrows (Bold, No Crossing) -->
        <mxCell id="10" value="Push" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;strokeColor=#4472c4;fontSize=10;fontStyle=1;" edge="1" parent="1" source="2" target="3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="11" value="Webhook" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;strokeColor=#4472c4;fontSize=10;fontStyle=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="3" target="5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="12" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=4;strokeColor=#666666;" edge="1" parent="1" source="5" target="6">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="13" value="Pass" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=4;strokeColor=#666666;fontSize=10;" edge="1" parent="1" source="6" target="7">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="14" value="Compile&#xa;&amp; Run" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=5;strokeColor=#ffa500;fontSize=11;fontStyle=1;" edge="1" parent="1" source="7" target="8">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="15" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=4;strokeColor=#666666;" edge="1" parent="1" source="8" target="9">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Row 3: External Outputs (Below, No Crossing) -->

        <!-- Model Registry -->
        <mxCell id="16" value="Model&#xa;Registry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#70ad47;strokeWidth=2;fontSize=11;dashed=1;dashPattern=8 8;" vertex="1" parent="1">
          <mxGeometry x="590" y="370" width="100" height="60" as="geometry"/>
        </mxCell>

        <!-- S3 Storage -->
        <mxCell id="17" value="S3&#xa;Storage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7f7f7f;strokeWidth=2;fontSize=11;dashed=1;dashPattern=8 8;" vertex="1" parent="1">
          <mxGeometry x="710" y="370" width="100" height="60" as="geometry"/>
        </mxCell>

        <!-- Model Serving -->
        <mxCell id="18" value="Model&#xa;Serving" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#ee0000;strokeWidth=2;fontSize=11;dashed=1;dashPattern=8 8;" vertex="1" parent="1">
          <mxGeometry x="830" y="370" width="100" height="60" as="geometry"/>
        </mxCell>

        <!-- Output connections (Downward, No Crossing) -->
        <mxCell id="19" value="Register" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#70ad47;dashed=1;fontSize=10;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="8" target="16">
          <mxGeometry x="-0.2" relative="1" as="geometry">
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="20" value="Export" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#7f7f7f;dashed=1;fontSize=10;exitX=0.75;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="8" target="17">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="21" value="Deploy" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#ee0000;dashed=1;fontSize=10;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="9" target="18">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Labels -->
        <mxCell id="22" value="External Services" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontStyle=2;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="470" y="370" width="100" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="23" value="LEFT-TO-RIGHT FLOW: Code → CI/CD → ML Execution → Model Deployment" style="text;html=1;strokeColor=none;fillColor=#ffffcc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=11;fontStyle=3;strokeColor=#ffa500;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="300" y="470" width="500" height="30" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
