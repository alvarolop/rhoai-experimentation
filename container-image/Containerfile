FROM registry.access.redhat.com/ubi9/python-312

LABEL maintainer="Alvaro Lopez Medina"
LABEL description="Custom image for RHOAI Kubeflow Pipelines CI/CD with Tekton"
LABEL io.openshift.tags="rhoai,kubeflow,pipelines,tekton,python"
LABEL io.k8s.description="Builder image for Red Hat OpenShift AI Pipelines with pre-installed KFP SDK and ML dependencies"
LABEL io.openshift.expose-services=""

USER 0

# Install system dependencies
RUN dnf install -y --setopt=tsflags=nodocs \
    git \
    && dnf clean all \
    && rm -rf /var/cache/dnf

# Install Python packages (aligned with RHOAI 3.3.x 2025.2 workbench versions)
# Using exact versions from s2i-generic-data-science-notebook:2025.2
RUN pip install --no-cache-dir \
    kfp==2.14.0 \
    kfp-kubernetes==1.3.0 \
    scikit-learn==1.7.0 \
    pandas==2.3.0 \
    numpy==2.3.0 \
    scipy==1.16.0 \
    matplotlib==3.10.0 \
    requests==2.32.3 \
    pylint==3.3.1 \
    flake8==7.1.1 \
    black==24.10.0

# Set working directory
WORKDIR /workspace

# Set permissions for OpenShift arbitrary user IDs
RUN chown -R 1001:0 /workspace && \
    chmod -R g=u /workspace

USER 1001

CMD ["/bin/bash"]
