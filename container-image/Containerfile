FROM registry.access.redhat.com/ubi9/python-311

LABEL maintainer="Alvaro Lopez Medina"
LABEL description="Custom image for RHOAI Kubeflow Pipelines CI/CD with Tekton"
LABEL io.openshift.tags="rhoai,kubeflow,pipelines,tekton,python"
LABEL io.k8s.description="Builder image for Red Hat OpenShift AI Pipelines with pre-installed KFP SDK and ML dependencies"
LABEL io.openshift.expose-services=""

USER 0

# Install system dependencies
RUN dnf install -y --setopt=tsflags=nodocs \
    git \
    && dnf clean all \
    && rm -rf /var/cache/dnf

# Install Python packages
RUN pip install --no-cache-dir \
    kfp==2.8.0 \
    scikit-learn==1.5.0 \
    pandas==2.2.2 \
    numpy==1.26.4 \
    requests==2.32.3 \
    pylint==3.1.0 \
    flake8==7.0.0 \
    black==24.3.0

# Set working directory
WORKDIR /workspace

# Set permissions for OpenShift arbitrary user IDs
RUN chown -R 1001:0 /workspace && \
    chmod -R g=u /workspace

USER 1001

CMD ["/bin/bash"]
